# Server
PORT=3001
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/mernshopping

# Required in production. Use a long random string (32+ bytes).
JWT_SECRET=replace_with_a_long_random_string

# Required for checkout. Use the test key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=

# Optional. Origin used for Stripe success/cancel URLs in production.
CLIENT_URL=
